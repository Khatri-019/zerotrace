cat > /mnt/d/zerotrace/.gitignore << 'EOF'
# BPF compiled objects
bpf/*.o

# Go build outputs
bin/
agent/loader/*_bpfel.go
agent/loader/*_bpfeb.go
agent/loader/*.o

# Go module cache
vendor/libbpf/

# Python virtual environment
venv/

# Node
ui/node_modules/
ui/dist/

# BadgerDB data
data/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Generated proto files (regenerated by protoc)
proto/*.pb.go

# Test artifacts
bench/results/
traces.json
graph.json

# Setup scripts (personal, not project)
setup.sh
run_test.sh
EOF

echo "done"